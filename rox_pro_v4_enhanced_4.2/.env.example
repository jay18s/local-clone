# ROX Proven Edge Engine v4.0 Unified — Environment Configuration
# Copy this file to .env and fill in your values

# ── Portfolio ────────────────────────────────────────────────────────────────
PORTFOLIO_VALUE=1000000

# ── Broker: Fyers (optional) ─────────────────────────────────────────────────
FYERS_ENABLED=false
FYERS_API_KEY=
FYERS_ACCESS_TOKEN=
FYERS_APP_ID=

# ── Broker: Zerodha (optional) ───────────────────────────────────────────────
ZERODHA_ENABLED=false
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# ── News API (optional) ──────────────────────────────────────────────────────
NEWS_API_ENABLED=false
NEWS_API_KEY=

# ── Redis cache (optional) ───────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ── F&O risk overrides ───────────────────────────────────────────────────────
MAX_OPTIONS_EXPOSURE=0.10
MAX_OPTION_PREMIUM=0.02
OPTIONS_DATA_SOURCE=nse

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
