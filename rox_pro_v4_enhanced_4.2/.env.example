# ═══════════════════════════════════════════════════════════════════
# ROX PROVEN EDGE ENGINE v6.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Migrated from Gemini to OpenRouter on 2026-04-17.

# ── OPENROUTER LLM API ────────────────────────────────────────────
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1
OPEN_ROUTER_API=sk-or-v1-XXXXXXXXXXXX
OPEN_ROUTER_MODEL=openrouter/free
OPEN_ROUTER_HTTP_REFERER=https://rox-engine.local
OPEN_ROUTER_X_TITLE=ROX Trading Engine

# ── Per-role model overrides (optional — defaults to OPEN_ROUTER_MODEL) ──
# ROX_FAST_MODEL=openrouter/free
# ROX_SMART_MODEL=openrouter/free
# ROX_PLANNER_MODEL=openrouter/free
# ROX_DEBATE_MODEL=openrouter/free
# ROX_ANALYSIS_MODEL=openrouter/free
# ROX_NEWS_MODEL=openrouter/free
# ROX_SWARM_MODEL=openrouter/free

# ── AI BRAIN (multi-provider meta-intelligence) ───────────────────
BRAIN_ENABLED=true
BRAIN_LLM_PROVIDER=openrouter      # anthropic | openai | openrouter | groq
BRAIN_MODEL=openrouter/free
BRAIN_MAX_TOKENS=8192
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# ── FYERS MARKET DATA ─────────────────────────────────────────────
FYERS_APP_ID=
FYERS_APP_SECRET=
FYERS_ACCESS_TOKEN=

# ── LLM TUNING ────────────────────────────────────────────────────
LLM_ENABLED=true
LLM_MODEL=openrouter/free
LLM_CACHE_TTL=300
LLM_TEMPERATURE=0.3

# ── SYSTEM ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
